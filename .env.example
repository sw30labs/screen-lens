# ScreenLens environment example
#
# Copy to .env. ScreenLens loads .env from the working directory or repository
# root automatically. Shell exports take precedence over this file.

# ── NVIDIA DGX Spark / vLLM ─────────────────────────────────────────────────
# Used by default on Linux/ARM64 and by setup_and_run_dgx.sh. The model
# is a multimodal Qwen checkpoint that can caption frames, perform OCR, and run
# text reconstruction through the same OpenAI-compatible endpoint.
#
# Replace the placeholder with a Hugging Face read token before the helper must
# start its own container. A token is not needed merely to reuse an already-ready
# exact-model service owned by DigitalTwin or another local stack.
HF_TOKEN=hf_replace_me
HF_HUB_DISABLE_XET=1

DGX_VENV_DIR=.venv-dgx
DGX_PYTHON_BIN=python3.12
DGX_HF_CACHE=.local-models/huggingface
DGX_VLLM_CACHE=.local-models/vllm

VLLM_IMAGE=vllm/vllm-openai@sha256:e4f88a835143cd22aee2397a26ec6bb80b3a4a6fe0c882bcbc63822904766089
VLLM_MODEL=nvidia/Qwen3.6-27B-NVFP4
VLLM_MODEL_REVISION=0893e1606ff3d5f97a441f405d5fc541a6bdf404
# Keep this paired with the selected checkpoint: modelopt for the checked
# NVIDIA NVFP4 model, or fp8 for Qwen/Qwen3.6-27B-FP8.
VLLM_QUANTIZATION=modelopt
# The checked NVFP4 model includes FP8 KV calibration. For checkpoints without
# calibrated KV scales, use auto to retain the model's BF16 cache precision.
VLLM_KV_CACHE_DTYPE=fp8
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=local
VLLM_GPU_MEMORY_UTILIZATION=0.45
VLLM_MAX_MODEL_LEN=262144
VLLM_START_TIMEOUT=1800
VLLM_LOG_TAIL=200

# setup_and_run_dgx.sh run exports these itself. They are shown here as the
# application-side contract for direct/manual DGX invocations.
#SCREENLENS_BACKEND=vllm
#SCREENLENS_DEVICE=cuda
#SCREENLENS_BATCH_SIZE=2

# ── oMLX / local OpenAI-compatible API ─────────────────────────────────────
# This remains the native Apple Silicon path and is independent of the DGX
# section above.
# Default API base. You may also paste the dashboard URL:
# http://127.0.0.1:8000/admin/dashboard
# ScreenLens normalizes root/dashboard URLs to /v1.
MLX_BASE_URL=http://127.0.0.1:8000/v1

# Required when oMLX authentication is enabled. Use one key variable.
MLX_API_KEY=your-omlx-api-key-here

# ── OCR (vision) model — REQUIRED for `transcribe`. MUST be vision-capable. ──
# This model READS the frames. A text-only model (MiniMax, DeepSeek, GPT-OSS)
# returns "no image provided" for every frame. List candidates + capability with
# `screenlens models`. Recommended default for dense document/code OCR
# (Qwen-VL lineage; bf16 = no quant loss). Thinking is auto-disabled for OCR.
OCR_MODEL=Qwen3.6-27B-bf16

# ── Text LLM — transcript seam/indent cleanup + summaries (never sees images) ─
# Used by captioning/summary paths too. A text-only model is fine here, but it
# MUST fit your oMLX memory ceiling (e.g. MiniMax-M3-4bit ~236GB will not load
# under a 71GB ceiling; Qwen3.6-27B-bf16 ~54GB fits). Cleanup is OFF by default
# in `transcribe` (opt in with --cleanup).
# If unset, ScreenLens falls back to OMLX_MODEL, LLM_MODEL, then "default".
MLX_MODEL=Qwen3.6-27B-bf16

# Alias variables are also supported for compatibility with oMLX naming.
# Leave these commented unless you prefer the OMLX_* names.
#OMLX_BASE_URL=http://127.0.0.1:8000/v1
#OMLX_API_KEY=your-omlx-api-key-here
#OMLX_MODEL=default

# Generic fallback model name used if MLX_MODEL/OMLX_MODEL are unset.
#LLM_MODEL=default

# ── Ollama fallback backend ────────────────────────────────────────────────
# Used only with --backend ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2-vision

# ── Common local overrides ─────────────────────────────────────────────────
# Increase if your oMLX model needs longer responses or large frame batches.
# These are documented config values; set via JSON config or CLI flags when
# possible because not every option is read directly from the environment.
# Apple Silicon commonly tolerates a larger batch, for example 4.
#SCREENLENS_OMLX_TIMEOUT_SECONDS=600
